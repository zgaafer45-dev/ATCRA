<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="sabry">


    <!-- Import sabry urdf file -->
    <xacro:include filename="$(find sabry)/urdf/sabry.urdf.xacro" />

    <!-- Import control_xacro -->
    <xacro:include filename="sabry.ros2_control.xacro" /> 
    <xacro:sabry_ros2_control />

</robot>
